{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "BotStrike default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "dialog:default",
    "process:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/botstrike-engine", "sidecar": true, "args": true }]
    },
    "shell:allow-kill"
  ]
}
