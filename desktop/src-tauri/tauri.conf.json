{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BotStrike",
  "version": "2.8.0",
  "identifier": "com.botstrike.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "BotStrike Trading Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/engine/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExOTQ4OUJGNEE4MzIwNTIKUldSU0lJTkt2NG1Vb2ZRSTdvVWhqQld0TThLZGVDZFJWcjBLYng2bEZtUG1uUHg5alZhOUdraDYK",
      "endpoints": [
        "https://github.com/FomoDonkey/BotStrike/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
