{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BotStrike",
  "version": "1.0.0",
  "identifier": "com.botstrike.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "BotStrike Trading Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:9420 http://127.0.0.1:9420 ws://localhost:9420 http://localhost:9420 https://api.binance.com wss://stream.binance.com:9443; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExOTQ4OUJGNEE4MzIwNTIKUldSU0lJTkt2NG1Vb2ZRSTdvVWhqQld0TThLZGVDZFJWcjBLYng2bEZtUG1uUHg5alZhOUdraDYK",
      "endpoints": [
        "https://github.com/FomoDonkey/BotStrike/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
