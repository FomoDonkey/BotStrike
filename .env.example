# Strike Finance API Keys
STRIKE_PUBLIC_KEY=your_ed25519_public_key_hex_64chars
STRIKE_PRIVATE_KEY=your_ed25519_private_key_hex_64chars

# URLs (defaults to mainnet, override for testnet)
# STRIKE_API_URL=https://api-v2-testnet.strikefinance.org
# STRIKE_PRICE_URL=https://api-v2-testnet.strikefinance.org/price
# STRIKE_WS_MARKET=wss://api-v2-testnet.strikefinance.org/ws/price
# STRIKE_WS_USER=wss://api-v2-testnet.strikefinance.org/ws/user-api

# Telegram Notifications (optional — leave empty to disable)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=your_chat_id_here
